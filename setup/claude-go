#!/bin/bash
# claude-go: Syncs skills from GitHub then launches Claude Code
# Usage: claude-go [project-name]
# Example: claude-go seekon.ai
# Skills source: github.com/watchdogpedro/claude-skills
# Personal rules: ~/.claude/CLAUDE-personal-rules.md (never overwritten)

PERSONAL_RULES="$HOME/.claude/CLAUDE-personal-rules.md"
CLAUDE_MD="$HOME/.claude/CLAUDE.md"
REPO="watchdogpedro/claude-skills"

# ─── Project Registry ────────────────────────────────────────────────────────
# Format: ["alias"]="local_path"
# Use any alias: claude-go seekon / claude-go seekon.ai / claude-go surnetics
declare -A PROJECTS
PROJECTS["seekon"]="/Users/pauldenman/seekon.ai"
PROJECTS["seekon.ai"]="/Users/pauldenman/seekon.ai"
PROJECTS["surnetics"]="/Users/pauldenman/surnetics"
PROJECTS["surnetics.com"]="/Users/pauldenman/surnetics"
PROJECTS["anglelock"]="/Users/pauldenman/anglelock-new"
PROJECTS["anglelockllc"]="/Users/pauldenman/anglelockllc.com"
PROJECTS["anglelockllc.com"]="/Users/pauldenman/anglelockllc.com"
PROJECTS["asc"]="/Users/pauldenman/asc-international"
PROJECTS["asc-international"]="/Users/pauldenman/asc-international"
PROJECTS["solderpaste"]="/Users/pauldenman/asc-international"
PROJECTS["linearmotion"]="/Users/pauldenman/linearmotion"
PROJECTS["linearshaftmotor"]="/Users/pauldenman/linearshaftmotor.ai"
PROJECTS["linearshaftmotor.ai"]="/Users/pauldenman/linearshaftmotor.ai"
PROJECTS["controlleddynamics"]="/Users/pauldenman/controlleddynamics"
PROJECTS["controlleddynamicsinc"]="/Users/pauldenman/controlleddynamicsinc.com"
PROJECTS["pauldenman"]="/Users/pauldenman/pauldenman.com"
PROJECTS["pauldenman.com"]="/Users/pauldenman/pauldenman.com"
PROJECTS["christina"]="/Users/pauldenman/christinanoellee.com"
PROJECTS["christinanoellee"]="/Users/pauldenman/christinanoellee.com"
PROJECTS["christinanoellee.com"]="/Users/pauldenman/christinanoellee.com"
# ─────────────────────────────────────────────────────────────────────────────

# List of skill files to pull from GitHub
SKILL_FILES=(
  "web-design-expert.md"
  "frontend-development.md"
  "test-driven-development.md"
  "webapp-testing.md"
  "distinctive-design/SKILL.md"
  "frontend-design/SKILL.md"
  "n8n-code-javascript/SKILL.md"
  "n8n-code-python/SKILL.md"
  "n8n-expression-syntax/SKILL.md"
  "n8n-mcp-tools-expert/SKILL.md"
  "n8n-node-configuration/SKILL.md"
  "n8n-validation-expert/SKILL.md"
  "n8n-workflow-patterns/SKILL.md"
)

# ─── Project lookup (first argument) ─────────────────────────────────────────
PROJECT_ARG="${1:-}"
PROJECT_DIR=""

if [ -n "$PROJECT_ARG" ]; then
  # Check registry first
  if [ -n "${PROJECTS[$PROJECT_ARG]+_}" ]; then
    PROJECT_DIR="${PROJECTS[$PROJECT_ARG]}"
  # Fallback: treat as a direct path
  elif [ -d "$PROJECT_ARG" ]; then
    PROJECT_DIR="$PROJECT_ARG"
  else
    echo "⚠️  Unknown project: '$PROJECT_ARG'"
    echo "   Known projects: ${!PROJECTS[@]}"
    echo "   Launching Claude in current directory..."
  fi
fi
# ─────────────────────────────────────────────────────────────────────────────

echo "Syncing skills from GitHub ($REPO)..."

# Start with personal rules
if [ ! -f "$PERSONAL_RULES" ]; then
  echo "ERROR: Personal rules file not found at $PERSONAL_RULES"
  echo "Launching Claude without sync..."
  exec claude
fi

cp "$PERSONAL_RULES" "$CLAUDE_MD"

# Add separator
echo "" >> "$CLAUDE_MD"
echo "---" >> "$CLAUDE_MD"
echo "" >> "$CLAUDE_MD"
echo "# SKILLS (Auto-synced from github.com/$REPO)" >> "$CLAUDE_MD"
echo "" >> "$CLAUDE_MD"

# Pull each skill file from GitHub
FAIL_COUNT=0
for skill in "${SKILL_FILES[@]}"; do
  CONTENT=$(gh api "repos/$REPO/contents/$skill" -H "Accept: application/vnd.github.raw" 2>/dev/null)
  if [ $? -eq 0 ] && [ -n "$CONTENT" ]; then
    echo "  Loaded: $skill"
    echo "" >> "$CLAUDE_MD"
    echo "---" >> "$CLAUDE_MD"
    echo "" >> "$CLAUDE_MD"
    echo "$CONTENT" >> "$CLAUDE_MD"
  else
    echo "  SKIPPED (not found): $skill"
    FAIL_COUNT=$((FAIL_COUNT + 1))
  fi
done

LOADED=$((${#SKILL_FILES[@]} - FAIL_COUNT))
echo ""
echo "Loaded $LOADED/${#SKILL_FILES[@]} skills from GitHub."

# ─── cd + git pull if project specified ──────────────────────────────────────
if [ -n "$PROJECT_DIR" ]; then
  echo ""
  echo "📁 Project: $PROJECT_ARG"
  echo "   Path: $PROJECT_DIR"
  cd "$PROJECT_DIR" || { echo "ERROR: Could not cd to $PROJECT_DIR"; exec claude; }
  echo "   Pulling latest from GitHub..."
  git pull 2>&1 | sed 's/^/   /'
  echo ""
fi
# ─────────────────────────────────────────────────────────────────────────────

echo "Launching Claude Code..."
echo ""

exec claude
