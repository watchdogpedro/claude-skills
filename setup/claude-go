#!/bin/bash
# claude-go: Syncs skills from GitHub then launches Claude Code
# Usage: claude-go [project-name]
# Example: claude-go seekon.ai
# Skills source: github.com/watchdogpedro/claude-skills
# Personal rules: ~/.claude/CLAUDE-personal-rules.md (never overwritten)

PERSONAL_RULES="$HOME/.claude/CLAUDE-personal-rules.md"
CLAUDE_MD="$HOME/.claude/CLAUDE.md"
REPO="watchdogpedro/claude-skills"

# ─── Project Registry ────────────────────────────────────────────────────────
# Use any alias: claude-go seekon / claude-go seekon.ai / claude-go surnetics
# Uses case statement for bash 3.2 compatibility (macOS default)
get_project_path() {
  case "$1" in
    seekon|seekon.ai)                          echo "/Users/pauldenman/seekon.ai" ;;
    surnetics|surnetics.com)                   echo "/Users/pauldenman/surnetics" ;;
    anglelock)                                 echo "/Users/pauldenman/anglelock-new" ;;
    anglelockllc|anglelockllc.com)             echo "/Users/pauldenman/anglelockllc.com" ;;
    asc|asc-international|solderpaste)         echo "/Users/pauldenman/asc-international" ;;
    linearmotion)                              echo "/Users/pauldenman/linearmotion" ;;
    linearshaftmotor|linearshaftmotor.ai)      echo "/Users/pauldenman/linearshaftmotor.ai" ;;
    controlleddynamics)                        echo "/Users/pauldenman/controlleddynamics" ;;
    controlleddynamicsinc|controlleddynamicsinc.com) echo "/Users/pauldenman/controlleddynamicsinc.com" ;;
    pauldenman|pauldenman.com)                 echo "/Users/pauldenman/pauldenman.com" ;;
    christina|christinanoellee|christinanoellee.com) echo "/Users/pauldenman/christinanoellee.com" ;;
    *)                                         echo "" ;;
  esac
}
# ─────────────────────────────────────────────────────────────────────────────

# List of skill files to pull from GitHub
SKILL_FILES=(
  "web-design-expert.md"
  "frontend-development.md"
  "test-driven-development.md"
  "webapp-testing.md"
  "distinctive-design/SKILL.md"
  "frontend-design/SKILL.md"
  "n8n-code-javascript/SKILL.md"
  "n8n-code-python/SKILL.md"
  "n8n-expression-syntax/SKILL.md"
  "n8n-mcp-tools-expert/SKILL.md"
  "n8n-node-configuration/SKILL.md"
  "n8n-validation-expert/SKILL.md"
  "n8n-workflow-patterns/SKILL.md"
)

# ─── Project lookup (first argument) ─────────────────────────────────────────
PROJECT_ARG="${1:-}"
PROJECT_DIR=""

if [ -n "$PROJECT_ARG" ]; then
  PROJECT_DIR="$(get_project_path "$PROJECT_ARG")"
  if [ -z "$PROJECT_DIR" ]; then
    # Fallback: treat as a direct path
    if [ -d "$PROJECT_ARG" ]; then
      PROJECT_DIR="$PROJECT_ARG"
    else
      echo "⚠️  Unknown project: '$PROJECT_ARG'"
      echo "   Known aliases: seekon, surnetics, anglelock, anglelockllc, asc, linearmotion, linearshaftmotor, controlleddynamics, controlleddynamicsinc, pauldenman, christina"
      echo "   Launching Claude in current directory..."
    fi
  fi
fi
# ─────────────────────────────────────────────────────────────────────────────

echo "Syncing skills from GitHub ($REPO)..."

# Start with personal rules
if [ ! -f "$PERSONAL_RULES" ]; then
  echo "ERROR: Personal rules file not found at $PERSONAL_RULES"
  echo "Launching Claude without sync..."
  claude
  kill -TERM $PPID 2>/dev/null || exit 0
fi

cp "$PERSONAL_RULES" "$CLAUDE_MD"

# Add separator
echo "" >> "$CLAUDE_MD"
echo "---" >> "$CLAUDE_MD"
echo "" >> "$CLAUDE_MD"
echo "# SKILLS (Auto-synced from github.com/$REPO)" >> "$CLAUDE_MD"
echo "" >> "$CLAUDE_MD"

# Pull each skill file from GitHub
FAIL_COUNT=0
for skill in "${SKILL_FILES[@]}"; do
  CONTENT=$(gh api "repos/$REPO/contents/$skill" -H "Accept: application/vnd.github.raw" 2>/dev/null)
  if [ $? -eq 0 ] && [ -n "$CONTENT" ]; then
    echo "  Loaded: $skill"
    echo "" >> "$CLAUDE_MD"
    echo "---" >> "$CLAUDE_MD"
    echo "" >> "$CLAUDE_MD"
    echo "$CONTENT" >> "$CLAUDE_MD"
  else
    echo "  SKIPPED (not found): $skill"
    FAIL_COUNT=$((FAIL_COUNT + 1))
  fi
done

LOADED=$((${#SKILL_FILES[@]} - FAIL_COUNT))
echo ""
echo "Loaded $LOADED/${#SKILL_FILES[@]} skills from GitHub."

# ─── cd + git pull if project specified ──────────────────────────────────────
if [ -n "$PROJECT_DIR" ]; then
  echo ""
  echo "📁 Project: $PROJECT_ARG"
  echo "   Path: $PROJECT_DIR"
  cd "$PROJECT_DIR" || { echo "ERROR: Could not cd to $PROJECT_DIR"; claude; kill -TERM $PPID 2>/dev/null; exit 0; }
  echo "   Pulling latest from GitHub..."
  git pull 2>&1 | sed 's/^/   /'
  echo ""
fi
# ─────────────────────────────────────────────────────────────────────────────

echo "Launching Claude Code (fresh session — no resume)..."
echo ""

# Run Claude fresh (no -c flag = no resume of last session)
claude --dangerously-skip-permissions

# After /exit — close this terminal window automatically
echo ""
echo "Session ended. Closing terminal..."
sleep 1
kill -TERM $PPID 2>/dev/null || exit 0
